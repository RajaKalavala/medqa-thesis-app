# Groq API
GROQ_API_KEY=your_groq_api_key_here

# Models (Groq open-source)
MEDQA_LLM_MODEL=llama-3.3-70b-versatile
MEDQA_JUDGE_MODEL=llama-3.1-8b-instant

# Local embedder (HuggingFace)
MEDQA_EMBED_MODEL=NeuML/pubmedbert-base-embeddings

# Paths
MEDQA_DATA_DIR=./data
MEDQA_INDEX_DIR=./data/indices
MEDQA_LOG_DIR=./logs
MEDQA_RESULTS_DIR=./results

# Runtime
MEDQA_ENV=development
MEDQA_LOG_LEVEL=INFO
MEDQA_API_HOST=0.0.0.0
MEDQA_API_PORT=8000

# MLflow (optional)
MLFLOW_TRACKING_URI=./results/mlruns
